{
  "name": "@y-mxgraph/iframe-bridge",
  "version": "0.1.0",
  "type": "module",
  "description": "Iframe bridge for y-mxgraph cross-tab collaboration",
  "license": "MIT",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./provider": {
      "import": "./src/provider.ts",
      "require": "./src/provider.ts",
      "types": "./src/provider.ts"
    },
    "./server": {
      "import": "./src/server.ts",
      "require": "./src/server.ts",
      "types": "./src/server.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "y-protocols": "^1.0.0",
    "yjs": "^13.6.0"
  },
  "devDependencies": {
    "@y-mxgraph/eslint-config": "workspace:*",
    "@y-mxgraph/typescript-config": "workspace:*",
    "jsdom": "^25.0.1",
    "typescript": "~5.5.4",
    "vitest": "^2.1.9"
  }
}