{
  "name": "y-mxgraph",
  "version": "0.2.2",
  "type": "module",
  "description": "Yjs binding for draw.io (mxGraph) documents",
  "keywords": [
    "yjs",
    "mxgraph",
    "drawio",
    "draw.io",
    "crdt",
    "collaboration",
    "real-time",
    "operational-transformation",
    "diagram",
    "graph",
    "sync"
  ],
  "license": "MIT",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build --config vite.config.ts && tsc --emitDeclarationOnly --declarationDir dist",
    "dev": "tsc --watch --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "y-protocols": "^1.0.0",
    "yjs": "^13.6.0"
  },
  "dependencies": {
    "colord": "^2.9.3",
    "lodash-es": "^4.17.21",
    "xml-js": "^1.6.11"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^2.0.0",
    "@y-mxgraph/eslint-config": "workspace:*",
    "@y-mxgraph/typescript-config": "workspace:*",
    "eslint": "^8.57.0",
    "typescript": "~5.5.4",
    "vite": "^5.1.4",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.0.0",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.27"
  }
}
